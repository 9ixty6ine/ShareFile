# =====================================================================
# SHAREfile – Environment Variables
# Copy backend/.env.example to backend/.env for local development.
# Set all production values as Environment Variables in your Vercel project.
# =====================================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Database ---
# Option A (recommended for cloud): single connection string from Neon / Supabase / Railway
DATABASE_URL=postgresql://user:password@host/dbname

# Option B (local dev): individual connection fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securevault
DB_USER=postgres
DB_PASSWORD=yourpassword

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# --- File Storage ---
# "local"  → saves to STORAGE_DIR (development only)
# "s3"     → uses S3-compatible cloud storage (required on Vercel / production)
STORAGE_PROVIDER=local
STORAGE_DIR=../storage/files
MAX_FILE_SIZE=104857600

# --- S3 / Cloudflare R2 (required when STORAGE_PROVIDER=s3) ---
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
# AWS S3 example:
#   S3_ENDPOINT=   (leave blank, SDK uses default)
#   S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_REGION=auto
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_access_key_id
S3_SECRET_KEY=your_secret_access_key

# --- CORS ---
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:5173